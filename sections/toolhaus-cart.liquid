{% comment %} sections/toolhaus-cart.liquid {% endcomment %}
{%- style -%}
  #th-cart-{{ section.id }} { background: #1D3A2A; color: #F5F3EE; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; min-height: 70vh; padding: 80px 40px; }
  #th-cart-{{ section.id }} * { box-sizing: border-box; }
  #th-cart-{{ section.id }} h1 { font-size: clamp(36px, 5vw, 56px); font-weight: 900; letter-spacing: -1px; margin: 0 0 40px; }
  #th-cart-{{ section.id }} .th-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.6fr 1fr; gap: 48px; }
  #th-cart-{{ section.id }} table { width: 100%; border-collapse: collapse; }
  #th-cart-{{ section.id }} th { text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: #7EC88A; padding: 0 0 16px; border-bottom: 1px solid rgba(126,200,138,0.2); font-weight: 700; }
  #th-cart-{{ section.id }} td { padding: 24px 0; border-bottom: 1px solid rgba(126,200,138,0.1); vertical-align: middle; }
  #th-cart-{{ section.id }} .th-item { display: flex; gap: 16px; align-items: center; }
  #th-cart-{{ section.id }} .th-item img { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; background: #2F5E42; }
  #th-cart-{{ section.id }} .th-item-title { font-weight: 600; font-size: 15px; }
  #th-cart-{{ section.id }} .th-item-variant { font-size: 12px; color: #E8E4DA; margin-top: 4px; }
  #th-cart-{{ section.id }} .th-qty { display: inline-flex; border: 1px solid rgba(126,200,138,0.3); border-radius: 6px; overflow: hidden; }
  #th-cart-{{ section.id }} .th-qty button { background: transparent; border: 0; color: #F5F3EE; width: 32px; height: 34px; cursor: pointer; font-size: 16px; }
  #th-cart-{{ section.id }} .th-qty button:hover { background: rgba(126,200,138,0.1); }
  #th-cart-{{ section.id }} .th-qty input { width: 40px; text-align: center; background: transparent; border: 0; color: #F5F3EE; font-size: 14px; outline: none; }
  #th-cart-{{ section.id }} .th-remove { background: transparent; border: 0; color: #E8E4DA; cursor: pointer; font-size: 12px; text-decoration: underline; margin-left: 12px; }
  #th-cart-{{ section.id }} .th-remove:hover { color: #7EC88A; }
  #th-cart-{{ section.id }} .th-summary { background: #2F5E42; border: 1px solid rgba(126,200,138,0.2); border-radius: 12px; padding: 32px; align-self: start; position: sticky; top: 110px; }
  #th-cart-{{ section.id }} .th-summary h3 { margin: 0 0 20px; font-size: 13px; text-transform: uppercase; letter-spacing: 2px; color: #7EC88A; }
  #th-cart-{{ section.id }} .th-row { display: flex; justify-content: space-between; padding: 10px 0; font-size: 15px; }
  #th-cart-{{ section.id }} .th-row.th-total { border-top: 1px solid rgba(126,200,138,0.2); margin-top: 12px; padding-top: 18px; font-size: 18px; font-weight: 800; }
  #th-cart-{{ section.id }} .th-note { width: 100%; background: rgba(15,32,24,0.4); border: 1px solid rgba(126,200,138,0.2); color: #F5F3EE; padding: 12px; border-radius: 6px; margin: 18px 0; font-size: 13px; outline: none; resize: vertical; min-height: 70px; font-family: inherit; }
  #th-cart-{{ section.id }} .th-checkout { display: block; width: 100%; background: #7EC88A; color: #1D3A2A; border: 0; padding: 16px; border-radius: 8px; font-weight: 800; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; text-align: center; text-decoration: none; margin-top: 12px; transition: transform 0.25s, box-shadow 0.25s; }
  #th-cart-{{ section.id }} .th-checkout:hover { transform: translateY(-3px); box-shadow: 0 12px 28px rgba(126,200,138,0.3); }
  #th-cart-{{ section.id }} .th-continue { display: block; text-align: center; color: #E8E4DA; margin-top: 16px; text-decoration: underline; text-underline-offset: 3px; font-size: 13px; }
  #th-cart-{{ section.id }} .th-empty { text-align: center; padding: 80px 20px; }
  #th-cart-{{ section.id }} .th-empty h2 { font-size: 40px; margin: 0 0 12px; font-weight: 900; }
  #th-cart-{{ section.id }} .th-empty p { color: #E8E4DA; margin: 0 0 28px; }
  #th-cart-{{ section.id }} .th-empty a { display: inline-block; background: #7EC88A; color: #1D3A2A; padding: 14px 28px; border-radius: 8px; text-decoration: none; font-weight: 800; text-transform: uppercase; font-size: 13px; letter-spacing: 1px; }
  @media (max-width: 860px) {
    #th-cart-{{ section.id }} { padding: 60px 20px; }
    #th-cart-{{ section.id }} .th-grid { grid-template-columns: 1fr; }
    #th-cart-{{ section.id }} .th-summary { position: static; }
    #th-cart-{{ section.id }} th:nth-child(2), #th-cart-{{ section.id }} td:nth-child(2) { display: none; }
  }
{%- endstyle -%}

<div id="th-cart-{{ section.id }}">
  <div style="max-width:1200px; margin:0 auto;">
    <h1>{{ section.settings.heading }}</h1>
  </div>

  {% if cart.item_count > 0 %}
    <div class="th-grid">
      <div>
        <table>
          <thead>
            <tr>
              <th>{{ section.settings.product_label }}</th>
              <th>{{ section.settings.price_label }}</th>
              <th>{{ section.settings.quantity_label }}</th>
              <th style="text-align:right;">{{ section.settings.total_label }}</th>
            </tr>
          </thead>
          <tbody>
            {% for line in cart.items %}
              <tr data-line-key="{{ line.key }}">
                <td>
                  <div class="th-item">
                    {% if line.image %}
                      <img src="{{ line.image | image_url: width: 160 }}" alt="{{ line.title | escape }}" loading="lazy">
                    {% else %}
                      <div style="width:80px;height:80px;background:#2F5E42;border-radius:8px;display:flex;align-items:center;justify-content:center;"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#7EC88A" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg></div>
                    {% endif %}
                    <div>
                      <div class="th-item-title"><a href="{{ line.url }}" style="color:inherit;text-decoration:none;">{{ line.product.title }}</a></div>
                      {% unless line.variant.title == 'Default Title' %}<div class="th-item-variant">{{ line.variant.title }}</div>{% endunless %}
                      <button class="th-remove" data-th-remove data-key="{{ line.key }}">{{ section.settings.remove_label }}</button>
                    </div>
                  </div>
                </td>
                <td>{{ line.price | money }}</td>
                <td>
                  <div class="th-qty">
                    <button data-th-qty data-key="{{ line.key }}" data-delta="-1" aria-label="Decrease">−</button>
                    <input type="number" value="{{ line.quantity }}" min="0" data-th-qty-input data-key="{{ line.key }}" aria-label="Quantity">
                    <button data-th-qty data-key="{{ line.key }}" data-delta="1" aria-label="Increase">+</button>
                  </div>
                </td>
                <td style="text-align:right; font-weight:700;">{{ line.line_price | money }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <aside class="th-summary">
        <h3>{{ section.settings.subtotal_label }}</h3>
        <div class="th-row th-total"><span>{{ section.settings.subtotal_label }}</span><span data-th-subtotal>{{ cart.total_price | money }}</span></div>
        <label style="display:block; margin-top:18px; font-size:12px; color:#E8E4DA; text-transform:uppercase; letter-spacing:1.5px;">{{ section.settings.note_label }}</label>
        <textarea class="th-note" data-th-note placeholder="..."></textarea>
        <a class="th-checkout" href="/checkout">{{ section.settings.checkout_label }}</a>
        <a class="th-continue" href="/collections/all">{{ section.settings.continue_label }}</a>
      </aside>
    </div>
  {% else %}
    <div class="th-empty">
      <h2>{{ section.settings.empty_heading }}</h2>
      <p>{{ section.settings.empty_paragraph }}</p>
      <a href="{{ section.settings.empty_button_url | default: '/collections/all' }}">{{ section.settings.empty_button_label }}</a>
    </div>
  {% endif %}
</div>

<script>
(function(){
  var root = document.getElementById('th-cart-{{ section.id }}'); if(!root) return;
  function reload(){ window.location.href = '/cart'; }
  function changeQty(key, qty){
    fetch('/cart/change.js', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ id: key, quantity: qty }) })
      .then(function(r){ return r.json(); }).then(function(){ reload(); }).catch(function(){ reload(); });
  }
  root.addEventListener('click', function(e){
    var q = e.target.closest('[data-th-qty]');
    if(q){ var k = q.dataset.key; var row = root.querySelector('tr[data-line-key="'+k+'"]'); var inp = row.querySelector('input[data-th-qty-input]'); var cur = parseInt(inp.value||'1',10); changeQty(k, Math.max(0, cur + parseInt(q.dataset.delta||'0',10))); return; }
    var r = e.target.closest('[data-th-remove]');
    if(r){ e.preventDefault(); changeQty(r.dataset.key, 0); }
  });
})();
</script>

{% schema %}
{
  "name": "Tool Haus Cart",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your cart" },
    { "type": "text", "id": "product_label", "label": "Product column label", "default": "Product" },
    { "type": "text", "id": "price_label", "label": "Price column label", "default": "Price" },
    { "type": "text", "id": "quantity_label", "label": "Quantity column label", "default": "Qty" },
    { "type": "text", "id": "total_label", "label": "Total column label", "default": "Total" },
    { "type": "text", "id": "subtotal_label", "label": "Subtotal label", "default": "Subtotal" },
    { "type": "text", "id": "note_label", "label": "Note label", "default": "Order notes (optional)" },
    { "type": "text", "id": "checkout_label", "label": "Checkout button label", "default": "Checkout" },
    { "type": "text", "id": "continue_label", "label": "Continue link label", "default": "Continue shopping" },
    { "type": "text", "id": "remove_label", "label": "Remove label", "default": "Remove" },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_heading", "label": "Empty heading", "default": "Your cart is empty." },
    { "type": "textarea", "id": "empty_paragraph", "label": "Empty paragraph", "default": "Looks like you haven't added anything yet." },
    { "type": "text", "id": "empty_button_label", "label": "Empty button label", "default": "Start shopping" },
    { "type": "url", "id": "empty_button_url", "label": "Empty button URL" }
  ],
  "presets": [{ "name": "Tool Haus Cart" }]
}
{% endschema %}
