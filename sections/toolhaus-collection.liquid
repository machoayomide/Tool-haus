{% comment %} sections/toolhaus-collection.liquid {% endcomment %}
{%- style -%}
  #th-collection-{{ section.id }} { background: #1D3A2A; color: #F5F3EE; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
  #th-collection-{{ section.id }} * { box-sizing: border-box; }
  #th-collection-{{ section.id }} .th-hero { padding: 80px 40px 48px; text-align: center; max-width: 900px; margin: 0 auto; }
  #th-collection-{{ section.id }} .th-hero h1 { font-size: clamp(40px, 6vw, 72px); font-weight: 900; letter-spacing: -1.5px; margin: 0 0 16px; }
  #th-collection-{{ section.id }} .th-hero p { color: #E8E4DA; font-size: 17px; line-height: 1.7; margin: 0; }
  #th-collection-{{ section.id }} .th-bar { max-width: 1280px; margin: 0 auto; padding: 20px 40px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(126,200,138,0.12); flex-wrap: wrap; gap: 16px; }
  #th-collection-{{ section.id }} .th-count { color: #E8E4DA; font-size: 13px; letter-spacing: 1px; text-transform: uppercase; }
  #th-collection-{{ section.id }} .th-sort { display: flex; align-items: center; gap: 10px; font-size: 13px; }
  #th-collection-{{ section.id }} .th-sort label { color: #7EC88A; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 700; font-size: 11px; }
  #th-collection-{{ section.id }} .th-sort select { background: rgba(15,32,24,0.6); color: #F5F3EE; border: 1px solid rgba(126,200,138,0.25); padding: 10px 14px; border-radius: 6px; font-size: 13px; outline: none; cursor: pointer; font-family: inherit; }
  #th-collection-{{ section.id }} .th-grid { max-width: 1280px; margin: 0 auto; padding: 40px 40px 80px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  #th-collection-{{ section.id }} .th-card { background: #2F5E42; border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit; transition: transform 0.3s cubic-bezier(0.22,1,0.36,1), box-shadow 0.3s; display: flex; flex-direction: column; opacity: 0; transform: translateY(30px); }
  #th-collection-{{ section.id }} .th-card.th-visible { opacity: 1; transform: translateY(0); }
  #th-collection-{{ section.id }} .th-card:hover { transform: translateY(-6px); box-shadow: 0 18px 40px rgba(126,200,138,0.18); }
  #th-collection-{{ section.id }} .th-img { aspect-ratio: 4/5; background: #0f2018; overflow: hidden; position: relative; }
  #th-collection-{{ section.id }} .th-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
  #th-collection-{{ section.id }} .th-card:hover .th-img img { transform: scale(1.05); }
  #th-collection-{{ section.id }} .th-info { padding: 22px 22px 26px; }
  #th-collection-{{ section.id }} .th-type { font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: #7EC88A; font-weight: 700; margin-bottom: 8px; }
  #th-collection-{{ section.id }} .th-title { font-weight: 700; font-size: 17px; margin: 0 0 10px; line-height: 1.3; }
  #th-collection-{{ section.id }} .th-price { font-size: 16px; color: #E8E4DA; }
  #th-collection-{{ section.id }} .th-pag { max-width: 1280px; margin: 0 auto; padding: 0 40px 80px; display: flex; justify-content: center; gap: 8px; }
  #th-collection-{{ section.id }} .th-pag a, #th-collection-{{ section.id }} .th-pag span { display: inline-flex; align-items: center; justify-content: center; min-width: 40px; height: 40px; padding: 0 14px; border: 1px solid rgba(126,200,138,0.25); border-radius: 6px; color: #F5F3EE; text-decoration: none; font-size: 14px; font-weight: 600; transition: all 0.2s; }
  #th-collection-{{ section.id }} .th-pag a:hover { border-color: #7EC88A; color: #7EC88A; }
  #th-collection-{{ section.id }} .th-pag span.th-cur { background: #7EC88A; color: #1D3A2A; border-color: #7EC88A; }
  #th-collection-{{ section.id }} .th-empty { max-width: 640px; margin: 0 auto; padding: 80px 24px 120px; text-align: center; }
  #th-collection-{{ section.id }} .th-empty h2 { font-size: 40px; font-weight: 900; margin: 0 0 16px; }
  #th-collection-{{ section.id }} .th-empty p { color: #E8E4DA; margin: 0 0 28px; }
  #th-collection-{{ section.id }} .th-empty a { display: inline-block; background: #7EC88A; color: #1D3A2A; padding: 14px 28px; border-radius: 8px; text-decoration: none; font-weight: 800; text-transform: uppercase; font-size: 13px; letter-spacing: 1px; }
  @media (max-width: 960px) {
    #th-collection-{{ section.id }} .th-grid { grid-template-columns: repeat(2, 1fr); padding: 30px 20px 60px; }
    #th-collection-{{ section.id }} .th-bar, #th-collection-{{ section.id }} .th-hero { padding-left: 20px; padding-right: 20px; }
  }
  @media (max-width: 560px) {
    #th-collection-{{ section.id }} .th-grid { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    #th-collection-{{ section.id }} .th-card { opacity: 1; transform: none; transition: none; }
  }
{%- endstyle -%}

<div id="th-collection-{{ section.id }}">
  <div class="th-hero">
    <h1>{{ collection.title }}</h1>
    {% if collection.description != blank %}<p>{{ collection.description }}</p>{% endif %}
  </div>

  {% if collection.products.size > 0 %}
    <div class="th-bar">
      <div class="th-count">{{ collection.products_count }} {{ section.settings.products_label }}</div>
      <div class="th-sort">
        <label for="th-sort-{{ section.id }}">{{ section.settings.sort_label }}</label>
        <select id="th-sort-{{ section.id }}" onchange="window.location.href=this.value">
          {% for opt in collection.sort_options %}
            <option value="{{ opt.url }}"{% if collection.sort_by == opt.value %} selected{% endif %}>{{ opt.name }}</option>
          {% endfor %}
        </select>
      </div>
    </div>

    <div class="th-grid" data-th-grid>
      {% for product in collection.products %}
        <a class="th-card" href="{{ product.url }}" data-th-reveal style="transition-delay: {{ forloop.index0 | times: 0.08 }}s">
          <div class="th-img">
            {% if product.featured_image %}
              <img src="{{ product.featured_image | image_url: width: 720 }}" alt="{{ product.title | escape }}" loading="lazy">
            {% else %}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#7EC88A" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              </div>
            {% endif %}
          </div>
          <div class="th-info">
            <div class="th-type">{{ product.type | default: 'Kit' }}</div>
            <div class="th-title">{{ product.title }}</div>
            <div class="th-price">{{ product.price | money }}</div>
          </div>
        </a>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <div class="th-pag">
        {% if paginate.previous %}<a href="{{ paginate.previous.url }}">← {{ paginate.previous.title }}</a>{% endif %}
        {% for part in paginate.parts %}
          {% if part.is_link %}<a href="{{ part.url }}">{{ part.title }}</a>
          {% elsif part.title == paginate.current_page %}<span class="th-cur">{{ part.title }}</span>
          {% else %}<span>{{ part.title }}</span>{% endif %}
        {% endfor %}
        {% if paginate.next %}<a href="{{ paginate.next.url }}">{{ paginate.next.title }} →</a>{% endif %}
      </div>
    {% endif %}
  {% else %}
    <div class="th-empty">
      <h2>{{ section.settings.empty_heading }}</h2>
      <p>{{ section.settings.empty_paragraph }}</p>
      <a href="{{ section.settings.empty_button_url | default: '/collections/all' }}">{{ section.settings.empty_button_label }}</a>
    </div>
  {% endif %}
</div>

<script>
(function(){
  var root = document.getElementById('th-collection-{{ section.id }}'); if(!root) return;
  var items = root.querySelectorAll('[data-th-reveal]');
  if(!('IntersectionObserver' in window)){ items.forEach(function(el){ el.classList.add('th-visible'); }); return; }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(en){ if(en.isIntersecting){ en.target.classList.add('th-visible'); io.unobserve(en.target); } });
  }, { threshold: 0.12 });
  items.forEach(function(el){ io.observe(el); });
})();
</script>

{% schema %}
{
  "name": "Tool Haus Collection",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "sort_label", "label": "Sort label", "default": "Sort by" },
    { "type": "text", "id": "products_label", "label": "Products count label", "default": "products" },
    { "type": "header", "content": "Empty state" },
    { "type": "text", "id": "empty_heading", "label": "Empty heading", "default": "Nothing here yet." },
    { "type": "textarea", "id": "empty_paragraph", "label": "Empty paragraph", "default": "This collection is being restocked. Check back soon." },
    { "type": "text", "id": "empty_button_label", "label": "Empty button label", "default": "Browse all" },
    { "type": "url", "id": "empty_button_url", "label": "Empty button URL" }
  ],
  "presets": [{ "name": "Tool Haus Collection" }]
}
{% endschema %}
