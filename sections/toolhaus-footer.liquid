{% comment %} sections/toolhaus-footer.liquid {% endcomment %}
{%- style -%}
  #th-footer-{{ section.id }} { background: #0f2018; color: #F5F3EE; font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; padding: 80px 40px 32px; }
  #th-footer-{{ section.id }} * { box-sizing: border-box; }
  #th-footer-{{ section.id }} .th-wrap { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr 1.4fr; gap: 48px; }
  #th-footer-{{ section.id }} .th-col h4 { font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: #7EC88A; margin: 0 0 18px; font-weight: 700; }
  #th-footer-{{ section.id }} .th-logo { font-weight: 900; font-size: 28px; display: inline-flex; gap: 6px; margin-bottom: 14px; }
  #th-footer-{{ section.id }} .th-logo .th-tool { color: #F5F3EE; }
  #th-footer-{{ section.id }} .th-logo .thhaus { color: #7EC88A; }
  #th-footer-{{ section.id }} .th-col p, #th-footer-{{ section.id }} .th-col a { color: #E8E4DA; font-size: 14px; line-height: 1.7; text-decoration: none; }
  #th-footer-{{ section.id }} .th-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  #th-footer-{{ section.id }} .th-col ul a:hover { color: #7EC88A; }
  #th-footer-{{ section.id }} .th-socials { display: flex; gap: 12px; margin-top: 18px; }
  #th-footer-{{ section.id }} .th-socials a { width: 38px; height: 38px; border: 1px solid rgba(126,200,138,0.3); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: #F5F3EE; transition: all 0.25s; }
  #th-footer-{{ section.id }} .th-socials a:hover { background: #7EC88A; color: #1D3A2A; border-color: #7EC88A; transform: translateY(-2px); }
  #th-footer-{{ section.id }} .th-news form { display: flex; gap: 8px; margin-top: 14px; }
  #th-footer-{{ section.id }} .th-news input { flex: 1; background: rgba(245,243,238,0.06); border: 1px solid rgba(126,200,138,0.25); color: #F5F3EE; padding: 12px 14px; border-radius: 6px; font-size: 13px; outline: none; }
  #th-footer-{{ section.id }} .th-news input:focus { border-color: #7EC88A; }
  #th-footer-{{ section.id }} .th-news button { background: #7EC88A; color: #1D3A2A; border: 0; padding: 12px 18px; border-radius: 6px; font-weight: 700; font-size: 13px; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; }
  #th-footer-{{ section.id }} .th-news button:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(126,200,138,0.25); }
  #th-footer-{{ section.id }} .th-bottom { max-width: 1280px; margin: 60px auto 0; padding-top: 28px; border-top: 1px solid rgba(126,200,138,0.12); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; font-size: 13px; color: #E8E4DA; }
  #th-footer-{{ section.id }} .th-payments { display: flex; gap: 8px; align-items: center; }
  #th-footer-{{ section.id }} .th-payments svg { height: 22px; width: auto; opacity: 0.85; }
  @media (max-width: 960px) {
    #th-footer-{{ section.id }} { padding: 60px 20px 24px; }
    #th-footer-{{ section.id }} .th-wrap { grid-template-columns: 1fr 1fr; gap: 36px; }
  }
  @media (max-width: 560px) {
    #th-footer-{{ section.id }} .th-wrap { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<footer id="th-footer-{{ section.id }}">
  <div class="th-wrap">
    <div class="th-col">
      <a href="/" class="th-logo" aria-label="Tool Haus"><span class="th-tool">Tool</span><span class="thhaus">Haus</span></a>
      <p>{{ section.settings.tagline }}</p>
      <div class="th-socials">
        {% if section.settings.instagram_url != blank %}<a href="{{ section.settings.instagram_url }}" aria-label="Instagram" target="_blank" rel="noopener"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>{% endif %}
        {% if section.settings.facebook_url != blank %}<a href="{{ section.settings.facebook_url }}" aria-label="Facebook" target="_blank" rel="noopener"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{% endif %}
        {% if section.settings.youtube_url != blank %}<a href="{{ section.settings.youtube_url }}" aria-label="YouTube" target="_blank" rel="noopener"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg></a>{% endif %}
        {% if section.settings.tiktok_url != blank %}<a href="{{ section.settings.tiktok_url }}" aria-label="TikTok" target="_blank" rel="noopener"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.69a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.84-.12z"/></svg></a>{% endif %}
      </div>
    </div>

    <div class="th-col">
      <h4>{{ section.settings.legal_col_title }}</h4>
      <ul>{% for link in linklists[section.settings.legal_menu].links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul>
    </div>
    <div class="th-col">
      <h4>{{ section.settings.products_col_title }}</h4>
      <ul>{% for link in linklists[section.settings.products_menu].links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul>
    </div>
    <div class="th-col">
      <h4>{{ section.settings.main_col_title }}</h4>
      <ul>{% for link in linklists[section.settings.main_menu].links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul>
    </div>

    <div class="th-col th-news">
      <h4>{{ section.settings.newsletter_col_title }}</h4>
      <p style="margin:0">{{ section.settings.newsletter_sub }}</p>
      {% form 'customer', class: 'th-newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div style="display:flex; gap:8px; margin-top:14px;">
          <input type="email" name="contact[email]" placeholder="you@brand.com" required aria-label="Email">
          <button type="submit">{{ section.settings.newsletter_button_label }}</button>
        </div>
      {% endform %}
    </div>
  </div>

  <div class="th-bottom">
    <div>{{ section.settings.copyright }}</div>
    <div class="th-payments">
      {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'th-pay-icon' }}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Tool Haus Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Everything your store needs to grow." },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© 2026 Tool Haus. All rights reserved." },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url", "id": "facebook_url", "label": "Facebook URL" },
    { "type": "url", "id": "youtube_url", "label": "YouTube URL" },
    { "type": "url", "id": "tiktok_url", "label": "TikTok URL" },
    { "type": "header", "content": "Columns" },
    { "type": "text", "id": "legal_col_title", "label": "Legal column title", "default": "Legal" },
    { "type": "link_list", "id": "legal_menu", "label": "Legal menu" },
    { "type": "text", "id": "products_col_title", "label": "Products column title", "default": "Products" },
    { "type": "link_list", "id": "products_menu", "label": "Products menu" },
    { "type": "text", "id": "main_col_title", "label": "Main column title", "default": "Company" },
    { "type": "link_list", "id": "main_menu", "label": "Main menu" },
    { "type": "text", "id": "newsletter_col_title", "label": "Newsletter column title", "default": "Newsletter" },
    { "type": "text", "id": "newsletter_sub", "label": "Newsletter subtext", "default": "New kits and free resources. Once a month." },
    { "type": "text", "id": "newsletter_button_label", "label": "Newsletter button label", "default": "Join" }
  ],
  "presets": [{ "name": "Tool Haus Footer" }]
}
{% endschema %}
